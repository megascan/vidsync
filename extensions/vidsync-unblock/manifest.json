{
  "manifest_version": 3,
  "name": "VidSync Unblock",
  "version": "2.1.0",
  "description": "VidSync: extension player streams multi‑GB video (Range, no page CORS). Host controls live in the player; room tab is the lobby.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["*://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://vidsync.ratt.ing/*",
        "http://localhost:4321/*",
        "http://127.0.0.1:4321/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_title": "VidSync Unblock",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["player.html", "player.js"],
      "matches": ["https://vidsync.ratt.ing/*", "http://localhost:4321/*"]
    }
  ]
}
