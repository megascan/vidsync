{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VidSync",
  "version": "0.1.3",
  "identifier": "ing.ratt.vidsync",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "VidSync",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https: wss: http: ws:; media-src 'self' http: https: blob:; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; object-src 'none'; base-uri 'self'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "msi", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "compression": "lzma"
      }
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUzQUJFRkRBRTA2RDdFRDIKUldUU2ZtM2cydStyVStKY2pkbjRmMjRDMzJLNTlBWDdEUjhZb2ZiZ1RVZnExNXpWR2F3KzVvU0cK",
      "endpoints": [
        "https://vidsync.ratt.ing/updater.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
