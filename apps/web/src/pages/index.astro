---
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeApp from "../components/home/HomeApp";
---

<BaseLayout title="VidSync — sync raw video streams">
  <main class="mx-auto flex min-h-full max-w-lg flex-col px-4 py-10">
    <header class="mb-8">
      <p class="font-mono text-xs tracking-widest text-[var(--color-accent)] uppercase">
        VidSync
      </p>
      <h1 class="mt-2 text-3xl font-semibold tracking-tight">
        Watch together. Stay in sync.
      </h1>
      <p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
        Anonymous sync rooms. Create empty, host queues public HTTPS streams
        (MP4, WebM, HLS). Everyone follows the host. No accounts.
      </p>
    </header>

    <HomeApp client:load />

    <aside
      class="mt-8 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-3 text-xs leading-relaxed text-[var(--color-muted)]"
    >
      <strong class="text-[var(--color-text)]">CORS:</strong>
      Browsers load media URLs directly — VidSync does not proxy bytes. Stubborn
      streams: optional
      <a
        class="text-[var(--color-accent)] underline-offset-2 hover:underline"
        href="https://github.com/megascan/vidsync/tree/master/extensions/vidsync-unblock"
        >VidSync Unblock</a
      >
      extension (fetch without page CORS; still must reach the URL).
    </aside>
  </main>
</BaseLayout>
