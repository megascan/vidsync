{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "vidsync-web",
  "main": "src/asset-worker.ts",
  "compatibility_date": "2026-04-07",
  "workers_dev": true,
  "preview_urls": true,
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    // Always run Worker so /r/:code can be rewritten without a browser redirect
    "run_worker_first": true,
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  },
  "routes": [
    {
      "pattern": "vidsync.ratt.ing",
      "custom_domain": true
    }
  ]
}
