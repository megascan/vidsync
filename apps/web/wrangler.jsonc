{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "vidsync-web",
  "compatibility_date": "2026-04-07",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "vidsync.ratt.ing",
      "custom_domain": true
    }
  ]
}
